# ── Wallet (NEVER commit the real .env file) ──────────────────────────
POLYGON_WALLET_PRIVATE_KEY=0x...your_metamask_private_key...
POLYMARKET_PROXY_ADDRESS=0x...your_safe_proxy_address...

# ── LLM APIs ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Trading config ────────────────────────────────────────────────────
BANKROLL=500
DRY_RUN=true
SCAN_INTERVAL_MINUTES=15

# ── Optional: Faster Polygon RPC ─────────────────────────────────────
# POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Optional: Model directory ─────────────────────────────────────────
# MODEL_DIR=./model
